# PostgreSQL connection string — format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://postgres:password@localhost:5432/cptedindia"

# NextAuth secret — generate with: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-here"

# Canonical URL of your deployment
NEXTAUTH_URL="http://localhost:3000"

# Public app URL (same as NEXTAUTH_URL in most cases)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Cloudflare R2 — image uploads (leave blank in local dev to use /public/uploads/ instead)
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME=""
R2_PUBLIC_URL=""   # e.g. https://pub-xxxx.r2.dev  or  https://cdn.cptedindia.com
